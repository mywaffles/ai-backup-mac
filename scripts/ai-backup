#!/usr/bin/env bash
# ai-backup — snapshot paths listed in ~/ai-backup-mac/backup-paths.conf

set -euo pipefail

REPO="$HOME/ai-backup-mac"
CONF="$REPO/backup-paths.conf"
LOG="$REPO/ai-backup.log"
TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')

[ -d "$REPO/.git" ] || { echo "Repo not found at $REPO"; exit 1; }
[ -f "$CONF" ]      || { echo "Config not found at $CONF"; exit 1; }

dest_for() {
  local src="$1"
  local name; name=$(basename "$src")
  if [ -f "$src" ]; then
    local parent; parent=$(basename "$(dirname "$src")" | tr ' ' '-')
    echo "files/$parent/$name"
  else
    echo "$name"
  fi
}

echo "ai-backup starting: $TIMESTAMP"
echo ""

# OpenClaw workspace has an embedded .git — sync into files/ to avoid git confusion
OC_WORKSPACE="$HOME/.openclaw/workspace"
if [ -d "$OC_WORKSPACE" ]; then
  mkdir -p "$REPO/files/openclaw-workspace"
  rsync -a --delete --exclude='.git' "$OC_WORKSPACE/" "$REPO/files/openclaw-workspace/"
  echo "  DIR ~/.openclaw/workspace -> files/openclaw-workspace/"
fi

while IFS= read -r line; do
  [[ "$line" =~ ^[[:space:]]*$  ]] && continue
  [[ "$line" =~ ^[[:space:]]*# ]] && continue
  SOURCE="${line/#\~/$HOME}"
  if [ ! -e "$SOURCE" ]; then
    echo "  SKIP (not found): $line"
    continue
  fi
  DEST_REL=$(dest_for "$SOURCE")
  DEST="$REPO/$DEST_REL"
  if [ -f "$SOURCE" ]; then
    mkdir -p "$(dirname "$DEST")"
    cp "$SOURCE" "$DEST"
    echo "  FILE $line -> $DEST_REL"
  else
    mkdir -p "$DEST"
    rsync -a --delete \
      --exclude='.git' --exclude='*.pyc' --exclude='__pycache__' \
      --exclude='.DS_Store' --exclude='*.log' --exclude='statsig/' --exclude='ide/' \
      "$SOURCE/" "$DEST/"
    echo "  DIR  $line -> $DEST_REL/"
  fi
done < "$CONF"

echo ""
cd "$REPO"
git add -A

if git diff --staged --quiet; then
  echo "Nothing changed since last backup."
  printf '[%s] BACKUP: no changes\n\n' "$TIMESTAMP" >> "$LOG"
  exit 0
fi

CHANGES=$(git diff --staged --stat)
echo "Changes:"
echo "$CHANGES"
git commit -m "backup: $TIMESTAMP"
echo ""
echo "Pushing to GitHub..."
git push

{
  printf '[%s] BACKUP\n' "$TIMESTAMP"
  echo "$CHANGES" | sed 's/^/  /'
  echo ""
} >> "$LOG"

git add "$LOG"
git diff --staged --quiet || git commit -m "log: backup at $TIMESTAMP"
git push

echo ""
echo "Backup complete: $TIMESTAMP"
